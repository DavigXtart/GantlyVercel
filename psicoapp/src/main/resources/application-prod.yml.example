spring:
  application:
    name: psicoapp
  mvc:
    pathmatch:
      matching-strategy: ant_path_matcher
  servlet:
    multipart:
      enabled: true
      max-file-size: 10MB
      max-request-size: 10MB
      file-size-threshold: 2KB

server:
  port: 8443
  ssl:
    # Configuración SSL/TLS 256-bit
    enabled: true
    key-store: classpath:keystore.p12
    key-store-password: ${SSL_KEYSTORE_PASSWORD:changeit}
    key-store-type: PKCS12
    key-alias: psicoapp
    # Protocolos TLS permitidos (solo versiones seguras)
    enabled-protocols: TLSv1.2,TLSv1.3
    # Cipher suites permitidas (solo con cifrado fuerte 256-bit)
    ciphers: TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,TLS_ECDHE_RSA_WITH_AES_256_CBC_SHA384,TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,TLS_ECDHE_ECDSA_WITH_AES_256_CBC_SHA384,TLS_DHE_RSA_WITH_AES_256_GCM_SHA384,TLS_DHE_RSA_WITH_AES_256_CBC_SHA256,TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305_SHA256,TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_CHACHA20_POLY1305_SHA256
    # Requerir certificado de cliente (opcional, para mayor seguridad)
    client-auth: none
    # Protocolo preferido
    protocol: TLS

# JWT Secret - DEBE tener al menos 32 bytes (256 bits) para AES-256
# Generar con: openssl rand -base64 32
JWT_SECRET: ${JWT_SECRET:your-256-bit-secret-key-here-minimum-32-bytes}

# Logging de auditoría RGPD
logging:
  level:
    AUDIT: INFO
  file:
    name: logs/audit.log
  pattern:
    file: "%d{yyyy-MM-dd HH:mm:ss} - %msg%n"
