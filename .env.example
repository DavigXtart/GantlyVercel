# === Google OAuth2 ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Base de datos ===
DB_URL=jdbc:mysql://localhost:3306/gantly?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your-db-password

# === Email ===
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# === CORS (origenes permitidos, separados por coma) ===
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4200

# === URL base del frontend ===
APP_BASE_URL=http://localhost:5173

# === Producción ===
# DATABASE_URL=jdbc:mysql://host:3306/gantly?useSSL=true&requireSSL=true&serverTimezone=UTC
# DATABASE_USER=gantly_prod_user
# DATABASE_PASSWORD=secure-password
# GOOGLE_OAUTH_CLIENT_ID=prod-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=prod-client-secret
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# JWT_SECRET=generate-with-openssl-rand-base64-32
