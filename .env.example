# ============================================================
# Gantly — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# For production, set these as env vars in Render/Vercel.
# ============================================================

# === Spring Profile ===
SPRING_PROFILES_ACTIVE=local  # local | prod

# === Base de datos (PostgreSQL) ===
# Local (Docker):
DATABASE_URL=jdbc:postgresql://localhost:5433/gantly
DATABASE_USER=postgres
DATABASE_PASSWORD=1234
# Producción (Supabase):
# DATABASE_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-supabase-password

# === Seguridad ===
# JWT — mínimo 32 bytes. Generar con: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-bytes-long-here
# PII Encryption — mínimo 32 chars. Generar con: openssl rand -base64 32
PII_ENCRYPTION_KEY=dev-pii-key-change-in-production-32chars

# === Google OAuth2 ===
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# === URLs ===
APP_BASE_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4200

# === Email (Resend — producción) ===
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@gantly.com
EMAIL_FROM_NAME=Gantly

# === Email (SMTP — fallback/desarrollo) ===
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# === Stripe (test mode para v1) ===
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Price IDs (test mode — de tu dashboard Stripe > Products)
STRIPE_PRICE_BASIC_MONTHLY=price_test_basic_monthly
STRIPE_PRICE_BASIC_YEARLY=price_test_basic_yearly
STRIPE_PRICE_PREMIUM_MONTHLY=price_test_premium_monthly
STRIPE_PRICE_PREMIUM_YEARLY=price_test_premium_yearly
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_test_enterprise_monthly
STRIPE_PRICE_ENTERPRISE_YEARLY=price_test_enterprise_yearly

# === Monitoring (opcional) ===
SENTRY_DSN=
BETTERSTACK_SOURCE_TOKEN=

# === Frontend (Vercel — build-time) ===
VITE_API_URL=http://localhost:8080/api
VITE_JITSI_DOMAIN=meet.jit.si
VITE_SENTRY_DSN=
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SRC=https://cloud.umami.is/script.js
